<UserControl x:Class="SolusManifestApp.Tools.CloudFix.CloudFixControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="900" HorizontalAlignment="Left" Margin="20">

            <!-- Status Card -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="SteamTools Cloud Fix"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Disables SteamTools' cloud API rewrite for games that break when saves are routed through app 760 (Steam Screenshots). Capcom games are auto-detected and blocked by default."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Status: " FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StatusText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Cloud Fix: " FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CloudFixState}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Game: " FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,10,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentGameText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Fix Capcom Game Saving"
                                Command="{Binding DisableCommand}"
                                IsEnabled="{Binding IsConnected}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8" Margin="0,0,8,0"
                                ToolTip="Block SteamTools from rewriting cloud saves for the current game"/>
                        <Button Content="Revert to SteamTools Behavior"
                                Command="{Binding RestoreCommand}"
                                IsEnabled="{Binding IsConnected}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8" Margin="0,0,8,0"
                                ToolTip="Re-enable SteamTools cloud rewriting for the current game"/>
                        <Button Content="{Binding MonitorButtonText}"
                                Command="{Binding ToggleMonitorCommand}"
                                IsEnabled="{Binding IsConnected}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8"
                                ToolTip="Automatically manage cloud rewriting per game based on the settings below"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Log Card -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Activity Log"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>
                    <ListBox ItemsSource="{Binding LogEntries}"
                             Height="180"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="Transparent"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource SecondaryDarkBrush}"
                             Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Per-Game Management Card -->
            <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Header row with title + save button -->
                    <DockPanel Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                            <TextBlock Text="Unsaved changes"
                                       Foreground="#FFCC44"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Button Content="Save Settings"
                                    Command="{Binding SaveSettingsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8"/>
                        </StackPanel>
                        <TextBlock Text="Per-Game Settings"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </DockPanel>

                    <TextBlock TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10">
                        <Run Text="Toggle &quot;Disable&quot; to block cloud rewriting for a game. Capcom games are auto-disabled for unlocked (SteamTools) games. Click Save Settings to persist changes."/>
                    </TextBlock>

                    <DataGrid ItemsSource="{Binding InstalledGames}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="Transparent"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource SecondaryDarkBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource SecondaryDarkBrush}"
                              MaxHeight="500"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Disable"
                                                    Binding="{Binding IsCloudFixDisabled, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="60"/>
                            <DataGridTextColumn Header="App ID" Binding="{Binding Game.AppId}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Game.Name}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Developer" Binding="{Binding Developer}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding OwnershipLabel}" Width="80" IsReadOnly="True"/>
                        </DataGrid.Columns>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBlockedPublisher}" Value="True">
                                        <Setter Property="Background" Value="#33FF4444"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
